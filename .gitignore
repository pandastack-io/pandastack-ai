# Local environment files (never commit secrets)
# Catch all .env variants; whitelist the safe examples below.
.env
.env.*
*.env
*.env.*
!.env.example
!.env.sample
!.env.template
!*.env.example
!*.env.sample
!*.env.template
!.env.local.example
!**/.env.example

# Python virtualenvs (third-party stdlib pulls trigger secret scanners)
.venv/
venv/
**/.venv/
**/__pycache__/
*.pyc

# Terraform state + plans + vars (NEVER commit — contain real credentials/JWTs)
*.tfstate
*.tfstate.*
*.tfstate.backup
*.tfplan
*.tfvars
*.tfvars.json
!*.tfvars.example
!*.tfvars.tftpl
.terraform/
.terraform.lock.hcl.bak
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

