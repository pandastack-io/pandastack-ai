# =============================================================================
# Pandastack — local dev environment
# Copy this file to `.env.local` and fill in real values. Never commit .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (auth + production Postgres)
# Dashboard: https://supabase.com/dashboard/project/<ref>
# -----------------------------------------------------------------------------

# Public project URL (Settings → API → Project URL)
SUPABASE_URL=

# Public anon key — safe to ship to the browser (Settings → API → anon public)
SUPABASE_ANON_KEY=

# Publishable key (the new sb_publishable_... format)
SUPABASE_PUBLISHABLE_KEY=

# Service-role key — NEVER ship to the browser. Server-side only.
# (Settings → API → service_role secret)
SUPABASE_SERVICE_ROLE_KEY=

# Secret key (the new sb_secret_... format)
SUPABASE_SECRET_KEY=

# JWKS endpoint we use to verify Supabase-issued JWTs in the Go API.
# Derived from SUPABASE_URL; override only if you proxy auth.
SUPABASE_JWKS_URL=

# -----------------------------------------------------------------------------
# Supabase Postgres connection
# Settings → Database → Connection string → "Transaction" (port 6543, pooled)
# Pattern: postgresql://postgres.<ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:6543/postgres
# -----------------------------------------------------------------------------
DATABASE_URL=

# Direct (non-pooled) connection on port 5432 — needed for migrations only.
# Settings → Database → Connection string → "Session" or "URI" mode.
DATABASE_DIRECT_URL=

# -----------------------------------------------------------------------------
# AWS — dev environment (us-east-1)
# Credentials live in ~/.aws/credentials (NOT here). We just record the profile.
# -----------------------------------------------------------------------------
AWS_PROFILE=default
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=

# Terraform state bucket (created once via `make tf-bootstrap`)
TF_STATE_BUCKET=pandastack-tfstate
TF_STATE_LOCK_TABLE=pandastack-tflock

# S3 bucket for canonical templates (vm.mem, vmstate, rootfs.ext4)
S3_TEMPLATE_BUCKET=pandastack-templates-dev

# -----------------------------------------------------------------------------
# Cloudflare (DNS for pandastack.dev)
# API token scope: Zone:DNS:Edit on pandastack.dev
# https://dash.cloudflare.com/profile/api-tokens
# -----------------------------------------------------------------------------
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DOMAIN=pandastack.dev

# -----------------------------------------------------------------------------
# Pandastack agent / API runtime
# -----------------------------------------------------------------------------
PANDASTACK_ENV=local
PANDASTACK_API_LISTEN=:8080
PANDASTACK_AGENT_SOCKET=/run/fcsandbox/agent.sock
PANDASTACK_DATA_DIR=/var/lib/pandastack
PANDASTACK_DB_DRIVER=sqlite              # sqlite | postgres
PANDASTACK_DB_DSN=                       # leave blank when using sqlite (uses $PANDASTACK_DATA_DIR/pandastack.db)

# Warm-pool tuning (carried over from speed-war)
PANDASTACK_WARMPOOL_SIZE=20
PANDASTACK_WARMPOOL_TEMPLATE=ubuntu-24.04
PANDASTACK_WARMPOOL_CPU=1
PANDASTACK_WARMPOOL_MEM_MB=1024
PANDASTACK_WARMPOOL_BURST=2

# Sandbox lifecycle (the new TTL feature)
PANDASTACK_DEFAULT_TTL_SECONDS=300       # 5 minutes default; per-sandbox override via API
PANDASTACK_REAPER_INTERVAL_SECONDS=30

# Optional speed flags (off by default — proven mixed on local APFS)
PANDASTACK_SNAPSHOT_PREFETCH=0
PANDASTACK_CPU_PINS=

# -----------------------------------------------------------------------------
# Apps (git-driven deploys) — stable per-app URL routing
# -----------------------------------------------------------------------------
# When set, running apps get a stable host-based URL of the form
#   https://{app-id}.<suffix>
# served by the in-API app-host router (resolves to the app's CURRENT sandbox
# per request, so the URL survives blue-green redeploys). Leave blank locally
# to fall back to the path-based form http://localhost:8080/v1/apps/{id}/proxy/.
# NOTE: served at the apex (no `.apps.` infix) so the single-level
# `*.<suffix>` wildcard cert covers it. Needs a `*.<suffix>` DNS record → API.
# Leave blank to inherit PANDASTACK_PREVIEW_HOST_SUFFIX (below): apps + preview
# URLs share the same apex domain, so setting the preview suffix alone is enough
# to get stable app URLs too. Set this only to override the app domain.
PANDASTACK_APP_HOST_SUFFIX=

# Public preview URLs for raw sandboxes: {port}-{sandbox-id}.<suffix>.
PANDASTACK_PREVIEW_HOST_SUFFIX=

# -----------------------------------------------------------------------------
# GitHub App (git-driven deploys: private clones, OAuth connect, webhooks)
# App ID + private key are the only hard requirement to mint installation
# tokens. Public repos and non-GitHub hosts always clone unauthenticated.
# Create the App, then copy the values below.
# https://docs.github.com/en/apps/creating-github-apps/writing-code-for-a-github-app/quickstart
# -----------------------------------------------------------------------------
# Numeric App ID (App settings → General → "App ID").
GITHUB_APP_ID=
# Optional single shared installation ID (Org/Account → Settings → GitHub Apps →
# Configure; the number at the end of the URL). Leave blank in the per-org OAuth
# flow — the API mints a token per installation discovered via the connect flow.
GITHUB_APP_INSTALLATION_ID=
# PEM private key. Single-line is fine — escape newlines as \n; the API
# normalizes them back to a real PEM block at runtime.
GITHUB_APP_PRIVATE_KEY=
# App "slug" (the URL handle, App settings → General → "Public link" tail). Used
# to build the install/connect URL: https://github.com/apps/<slug>/installations/new
GITHUB_APP_SLUG=
# OAuth credentials (App settings → General → "Client ID" / "Client secrets").
# Enable "Request user authorization (OAuth) during installation" so the connect
# callback receives a user code alongside installation_id. Used transiently to
# identify the connecting user — the user token is never persisted.
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Webhook secret (App settings → General → "Webhook secret"). Verifies the
# X-Hub-Signature-256 HMAC on POST /v1/webhooks/github. Required for auto-deploy.
GITHUB_APP_WEBHOOK_SECRET=
# Dashboard base URL the GitHub connect callback redirects back to after a
# successful install (default http://localhost:3000 for local dev).
PANDASTACK_DASHBOARD_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
PANDASTACK_METRICS_LISTEN=:9100
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_URL=http://localhost:9090

# -----------------------------------------------------------------------------
# Dashboard (Next.js — values prefixed NEXT_PUBLIC_ are exposed to browser)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_PANDASTACK_ENV=local

# PostHog product analytics (dashboard + marketing). Leave blank to disable
# (analytics becomes a safe no-op). Key: PostHog → Project Settings → Project API Key.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
